# ============================================
# interview-buddy — 环境变量示例文件
# 复制此文件为 .env.local 并填写实际值
# ⚠️ .env.local 已加入 .gitignore，绝不提交！
# ============================================

# ============================================
# 数据库
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/interview_buddy_dev"
# 生产示例 (Neon): postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/interview_buddy?sslmode=require

# ============================================
# Redis
# ============================================
REDIS_URL="redis://localhost:6379"
# 生产示例 (Upstash): rediss://default:pass@xxx.upstash.io:6379

# ============================================
# AI Providers (按优先级)
# ============================================
# 主 Provider - Minimax
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.MiniMax.chat/v1
MINIMAX_MODEL=MiniMax-M3

# 备 Provider - Claude
ANTHROPIC_API_KEY=

# 备 Provider - DeepSeek
DEEPSEEK_API_KEY=

# ============================================
# 邮件 (复用 OpCone 方案)
# ============================================
SMTP_HOST=gz-smtp.qcloudmail.com
SMTP_PORT=465
SMTP_USER=nodemailer@taomyst.top
SMTP_PASSWORD=
SMTP_FROM_NAME=Interview Buddy

# ============================================
# 微信支付
# ============================================
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_NOTIFY_URL=https://your-domain.com/api/payment/webhook

# ============================================
# JWT
# ============================================
JWT_SECRET=please-change-me-to-a-random-32-char-string-min
JWT_EXPIRES_IN=7d

# ============================================
# 应用配置
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
FREE_DAILY_QUOTA=3
PAID_PRICE_CNY=990  # 9.90 元 = 990 分

# ============================================
# 复利工程
# ============================================
COMPOUND_ENABLED=true
KNOWLEDGE_DIR=.knowledge
