// 这是 interview-buddy 的 Prisma schema
// 11 张表，详见 docs/TECHNICAL_DESIGN.md § 3
// Provider: 兼容 PostgreSQL / MySQL（生产用 TiDB MySQL）

generator client {
  provider      = "prisma-client-js"
  // Phase 14.22 ROOT CAUSE 修复：
  //   EdgeOne Pages 镜像 = Amazon Linux 2 + OpenSSL 1.1.1
  //   部署包超 128MiB 限制（145MiB）→ 删 darwin + linux-musl 节省 ~62MB
  // 覆盖矩阵（精简到 EdgeOne 必需）：
  //   - native: EdgeOne build env (Linux glibc) 自动探测 → linux + libssl
  //   - rhel-openssl-1.1.x: 兜底，万一 runtime 探测结果不一致
  //   - rhel-openssl-3.0.x: 兜底，万一 OpenSSL 3 镜像
  binaryTargets = ["native", "rhel-openssl-1.1.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// 1. User — 用户表
// ============================================
model User {
  id           String  @id @default(cuid())
  email        String  @unique
  passwordHash String
  nickname     String?
  avatarUrl    String?

  // 用户画像
  age         Int?
  city        String?
  currentRole String?

  // 状态
  emailVerified Boolean   @default(false)
  verifyCode    String?
  verifyExpiry  DateTime?

  // 计费
  freeQuotaUsed Int @default(0)
  paidQuota     Int @default(0)

  // 时间戳
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // 关系
  resumes     Resume[]
  interviews  Interview[]
  payments    Payment[]
  trackEvents TrackEvent[]
  feedbacks   Feedback[]

  @@index([email])
  @@map("users")
}

// ============================================
// 2. Resume — 简历表
// ============================================
model Resume {
  id       String  @id @default(cuid())
  userId   String
  fileUrl  String?
  fileHash String
  rawText  String  @db.Text
  parsed   Json

  // 关键字段
  name              String?
  currentCompany    String?
  currentTitle      String?
  yearsOfExperience Int?
  city              String?
  techStack         Json // MySQL 兼容：JSON 列（PG 原生 String[]）

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  interviews Interview[]

  // Phase 13.8 修复 #134：dedup 改为 (userId, fileHash) 复合唯一
  // 之前 fileHash @unique 是全局唯一 → 不同 user 上传相同文件触发 P2002
  // → 即使 race catch 重读，user B 也查不到自己的 dedup 记录（被 user A 占用）→ 500
  // 改为 per-user 复合唯一：每个 user 独立 dedup，语义正确，race 恢复按 (userId, fileHash) 查
  @@unique([userId, fileHash], name: "userId_fileHash_unique")
  @@index([userId, createdAt])
  @@index([fileHash])
  @@map("resumes")
}

// ============================================
// 3. Scenario — 16 关配置表
// ============================================
model Scenario {
  id                String @id @default(cuid())
  company           String
  role              String
  level             String
  interviewerPrompt String @db.Text
  scoringWeights    Json
  difficultyPrompt  String @db.Text
  estimatedDurationMin Int      @default(20)
  questionPoolSize     Int      @default(50)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())

  interviews Interview[]

  @@unique([company, role, level])
  @@index([company, isActive])
  @@map("scenarios")
}

// ============================================
// 4. Interview — 面试记录
// ============================================
// InterviewStatus: IN_PROGRESS | COMPLETED | ABANDONED | TIMEOUT
// (MySQL 不支持 ENUM，用 String + 应用层校验)

model Interview {
  id         String @id @default(cuid())
  userId     String
  resumeId   String
  scenarioId String

  startedAt   DateTime  @default(now())
  endedAt     DateTime?
  durationSec Int?

  status      String  @default("IN_PROGRESS") // InterviewStatus
  isFreeQuota Boolean @default(true)
  paymentId   String?

  totalScore Float?

  user     User      @relation(fields: [userId], references: [id])
  resume   Resume    @relation(fields: [resumeId], references: [id])
  scenario Scenario  @relation(fields: [scenarioId], references: [id])
  messages Message[]
  report   Report?

  @@index([userId, startedAt])
  @@index([status])
  @@map("interviews")
}

// ============================================
// 5. Message — 问答历史
// ============================================
// MessageRole: USER | INTERVIEWER | SYSTEM

model Message {
  id          String   @id @default(cuid())
  interviewId String
  role        String // MessageRole
  content     String   @db.Text
  category    String?
  difficulty  String?
  latencyMs   Int?
  createdAt   DateTime @default(now())

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@index([interviewId, createdAt])
  @@map("messages")
}

// ============================================
// 6. Report — 评分报告
// ============================================
model Report {
  id               String   @id @default(cuid())
  interviewId      String   @unique
  totalScore       Float
  dimensionScores  Json
  improvements     Json
  cohortRank       String?
  cohortPercentile Float?
  generatedAt      DateTime @default(now())

  interview   Interview    @relation(fields: [interviewId], references: [id])
  agentScores AgentScore[]

  @@map("reports")
}

// ============================================
// 7. AgentScore — 多 Agent 评分明细
// ============================================
model AgentScore {
  id              String   @id @default(cuid())
  reportId        String
  agentName       String
  agentVersion    String
  totalScore      Float
  dimensionScores Json
  reasoning       String   @db.Text
  durationMs      Int
  createdAt       DateTime @default(now())

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@map("agent_scores")
}

// ============================================
// 8. Payment — 支付记录
// ============================================
// PaymentStatus: PENDING | PAID | FAILED | REFUNDED | CANCELLED

model Payment {
  id            String    @id @default(cuid())
  userId        String
  amount        Int
  currency      String    @default("CNY")
  status        String    @default("PENDING") // PaymentStatus
  outTradeNo    String    @unique
  transactionId String?
  prepayId      String?
  productType   String    @default("interview_quota")
  quantity      Int       @default(1)
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([status])
  @@map("payments")
}

// ============================================
// 9. RateLimit — 限流记录
// ============================================
model RateLimit {
  id           String   @id @default(cuid())
  userId       String
  resourceType String
  windowStart  DateTime
  count        Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, resourceType, windowStart])
  @@index([userId, resourceType])
  @@map("rate_limits")
}

// ============================================
// 10. TrackEvent — 轻量埋点
// ============================================
model TrackEvent {
  id         String   @id @default(cuid())
  userId     String?
  eventName  String
  properties Json
  sessionId  String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([eventName, createdAt])
  @@index([userId, createdAt])
  @@map("track_events")
}

// ============================================
// 11. CaseStory — 35+ 真人案例（DB 索引，详情在 YAML）
// ============================================
model CaseStory {
  id         String   @id @default(cuid())
  storyKey   String   @unique
  yamlPath   String
  company    String
  role       String
  level      String
  title      String
  age        Int
  anonymized Boolean  @default(true)
  summary    String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([company, role, level])
  @@map("case_stories")
}

// ============================================
// 12. Feedback — 客服通道 / 用户反馈（Phase 13.5）
// ============================================
// FeedbackCategory: BUG | UX | FEATURE | ACCOUNT | OTHER
// FeedbackStatus:   PENDING | IN_PROGRESS | RESOLVED | SPAM
// (MySQL 不支持 ENUM，用 String + 应用层校验)
//
// 设计目标：
// - 匿名可用（userId nullable），已登录用户自动关联
// - 联系方式 + 联系邮箱用于运营回复
// - 同 IP / 邮箱 限流 + 蜜罐（复用 anti-abuse 三件套）
// - 邮件通知 support@taomyst.top
// - admin 角色可标记 resolved
model Feedback {
  id            String   @id @default(cuid())
  userId        String?  // 匿名（null）/ 已登录用户（cuid）
  category      String   // FeedbackCategory
  content       String   @db.Text
  contactEmail  String?  // 用户留的联系方式（可空）
  userAgent     String?  @db.Text
  ipAddress     String?  // 用户 IP（用于限流 + 反垃圾）
  status        String   @default("PENDING") // FeedbackStatus
  resolvedAt    DateTime?
  resolvedBy    String?  // admin userId
  adminNote     String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([ipAddress, createdAt])
  @@index([userId, createdAt])
  @@map("feedbacks")
}
