{
  "name": "interview-buddy",
  "version": "0.1.0",
  "description": "AI 面试陪练 - 35+ 群体的真实面试模拟",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:perf": "k6 run tests/perf/script.js",
    "audit": "pnpm audit --json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "compound": "bash scripts/compound.sh",
    "review": "bash scripts/review.sh",
    "elf-g": "bash scripts/elf-g.sh",
    "env-check": "bash scripts/env-check.sh",
    "prepare": "husky install"
  },
  "keywords": [
    "ai",
    "interview",
    "35plus",
    "nextjs"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  },
  "dependencies": {
    "@prisma/client": "~5.20.0",
    "next": "14.2.35",
    "prisma": "~5.20.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "eslint-config-prettier": "^9.1.2",
    "husky": "^8.0.0",
    "lint-staged": "^15.5.2",
    "postcss": "^8.4.31",
    "prettier": "~3.3.3",
    "tailwindcss": "~3.4.19",
    "typescript": "5.5.4"
  }
}
