# .claudeignore - 由 Claude Code 自动生成（来自 ~/.claude/claudeignore-template）
# 如需调整，编辑本文件即可，下次 SessionStart 不会覆盖（脚本检测了文件存在）

# ============================================================
# 依赖与构建产物（重点忽略）
# ============================================================
node_modules/
.next/
out/
dist/
build/
*.tsbuildinfo

# Python 构建产物
__pycache__/
*.pyc
*.pyo
*.pyd
.mypy_cache/
.pytest_cache/
.ruff_cache/
*.egg-info/
.venv/
venv/

# Rust / Go 构建产物
target/
*.exe
*.dll
*.so
*.dylib

# Java / Kotlin / Scala
*.class
*.jar
.gradle/
build/

# ============================================================
# 锁文件（按需启用——团队协作需要时取消注释）
# ============================================================
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
# poetry.lock
# Pipfile.lock
# Cargo.lock

# ============================================================
# 日志与临时文件
# ============================================================
*.log
*.tmp
*.bak
*.swp
*~
.DS_Store

# ============================================================
# 版本控制与 IDE
# ============================================================
.git/
.idea/
.vscode/
*.code-workspace

# ============================================================
# 图片/媒体（大文件，按需启用）
# ============================================================
# *.png
# *.jpg
# *.jpeg
# *.gif
# *.svg
# *.ico
# *.webp
# *.mp4
# *.mp3
# *.woff
# *.woff2
# *.ttf
# *.eot

# ============================================================
# 数据与缓存
# ============================================================
*.db
*.sqlite3
.cache/
coverage/
.nyc_output/

# ============================================================
# 环境配置（永远忽略 .env）
# ============================================================
.env
.env.*
!.env.example

# ============================================================
# 压缩/混淆产物
# ============================================================
*.min.js
*.min.css
*.map

# ============================================================
# 反忽略示例（如需保留特定文件）
# ============================================================
# !data/important.db
# !docs/**/*.md